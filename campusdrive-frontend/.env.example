# ================================================
# Google AdSense Configuration
# ================================================
# Get these from: https://www.google.com/adsense
#
# Publisher ID (looks like: ca-pub-1234567890123456)
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Ad Slot IDs — create separate ad units in AdSense dashboard for each type
VITE_ADSENSE_SLOT_BANNER=XXXXXXXXXX
VITE_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
VITE_ADSENSE_SLOT_INLINE=XXXXXXXXXX
VITE_ADSENSE_SLOT_FOOTER=XXXXXXXXXX

# ================================================
# API Base URL
# ================================================
VITE_API_URL=/api
